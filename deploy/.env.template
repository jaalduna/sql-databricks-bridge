# =============================================================================
# SQL-Databricks Bridge - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your environment.

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# =============================================================================
# SQL SERVER CONNECTION
# =============================================================================
SQLSERVER_HOST=your-sql-server.domain.local
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=YOUR_DATABASE
SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server
SQLSERVER_TRUST_CERT=true
SQLSERVER_USE_WINDOWS_AUTH=true

# =============================================================================
# DATABRICKS - Azure Workspace
# =============================================================================
DATABRICKS_HOST=https://adb-XXXXXXXXXXXXX.X.azuredatabricks.net/
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_WAREHOUSE_ID=XXXXXXXXXXXXXXXX

# =============================================================================
# UNITY CATALOG - Default Configuration
# =============================================================================
DATABRICKS_CATALOG=000-sql-databricks-bridge
DATABRICKS_SCHEMA=colombia
DATABRICKS_VOLUME=files

# =============================================================================
# EXTRACTION SETTINGS
# =============================================================================
EXTRACTION_CHUNK_SIZE=100000
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
QUERY_ROW_LIMIT=0
LOOKBACK_MONTHS=24
MAX_PARALLEL_QUERIES=4

# =============================================================================
# SYNC SETTINGS
# =============================================================================
POLLING_INTERVAL_SECONDS=10
MAX_EVENTS_PER_POLL=100
EVENTS_TABLE=bridge.events.bridge_events

# =============================================================================
# QUERIES PATH
# =============================================================================
QUERIES_PATH=queries

# =============================================================================
# AUTH AND PERMISSIONS
# =============================================================================
AUTH_ENABLED=false
# PERMISSIONS_FILE=       # empty = use bundled default
PERMISSIONS_HOT_RELOAD=true
