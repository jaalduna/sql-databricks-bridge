# =============================================================================
# SQL-Databricks Bridge - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the 4 variables requeridas.
# Todo lo demas tiene defaults que funcionan en produccion y se puede dejar en blanco.

# =============================================================================
# REQUERIDAS — Completar con los datos del workspace Databricks
# =============================================================================
DATABRICKS_HOST=https://adb-XXXXXXXXXXXXX.X.azuredatabricks.net/
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DATABRICKS_WAREHOUSE_ID=XXXXXXXXXXXXXXXX
DATABRICKS_CATALOG=000-sql-databricks-bridge

# =============================================================================
# OPCIONALES — Se pueden dejar en blanco (usan defaults de produccion)
# =============================================================================

# SQL Server: host y database se resuelven automaticamente por pais
# via kantar_db_handler. No necesitan configuracion.
# SQLSERVER_DRIVER=ODBC Driver 17 for SQL Server   # default: Driver 17
# SQLSERVER_USE_WINDOWS_AUTH=true                   # default: true (Windows Auth)

# Databricks extras:
# DATABRICKS_SCHEMA=default       # esquema Unity Catalog (default: "default")
# DATABRICKS_VOLUME=              # nombre del volume para archivos

# Extraccion:
# QUERIES_PATH=queries            # ruta a directorio de queries SQL
# LOOKBACK_MONTHS=24              # meses de historia (filtro rolling)
# MAX_PARALLEL_QUERIES=4          # queries en paralelo por job
# QUERY_ROW_LIMIT=0               # limite de filas por query (0 = sin limite)

# Servicio:
# AUTH_ENABLED=true               # habilitar autenticacion por token
# LOG_LEVEL=INFO                  # nivel de logging
# API_PORT=8000                   # puerto del servidor
